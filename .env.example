# =============================================================================
# Shotgun Ninjas Video Engine — environment variables
# =============================================================================
# Copy this file to `.env` and fill in the values for any local-dev only
# overrides. On Replit, set these via the Secrets pane (App Storage → Secrets)
# rather than committing them to git. Never commit a real `.env` to source.
#
# All variables marked REQUIRED must be present for the API server to boot.
# =============================================================================

# -----------------------------------------------------------------------------
# Core runtime
# -----------------------------------------------------------------------------

# REQUIRED. The TCP port each service listens on. On Replit this is injected
# automatically by the workflow per artifact — do NOT hard-code 3000/8080 in
# code. Local dev fallback only.
PORT=8080

# REQUIRED for the Vite-based artifacts (web app + mockup sandbox). Sets the
# Vite `base` URL so client routing works behind the Replit shared proxy.
# Both Vite configs throw at startup if this is missing.
#   - For the web app local dev:   BASE_PATH=/
#   - For the mockup sandbox:      BASE_PATH=/__mockup
# On Replit the platform injects the right value per artifact automatically.
BASE_PATH=/

# Optional. `development` enables verbose pino-pretty logs and permissive CORS.
# `production` enables strict CORS and disables stack-trace responses.
NODE_ENV=development

# Optional. Comma-separated list of origins allowed to call the API in
# production. Leave unset in development to allow all origins. Example:
#   ALLOWED_ORIGINS=https://shotgun-ninjas.replit.app,https://example.com
ALLOWED_ORIGINS=

# -----------------------------------------------------------------------------
# Database (PostgreSQL via Drizzle ORM)
# -----------------------------------------------------------------------------

# REQUIRED. PostgreSQL connection string. On Replit, the built-in Postgres
# integration provides this automatically — no need to set it manually.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL=postgres://user:password@localhost:5432/shotgun_ninjas

# -----------------------------------------------------------------------------
# Sessions / cookies
# -----------------------------------------------------------------------------

# REQUIRED in production. Random 32+ byte string used to sign session cookies.
# On Replit this is provided automatically. To generate one locally:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-string

# -----------------------------------------------------------------------------
# Billing
# -----------------------------------------------------------------------------

# Selects which billing provider the API server uses.
#   - `mock` (default) → in-DB MockBillingProvider, no network calls
#   - `stripe`         → reserved for the future StripeBillingProvider; today
#                        this value logs a warning and falls back to mock
BILLING_PROVIDER=mock

# -----------------------------------------------------------------------------
# Stripe (reserved — not yet wired into the live billing provider)
# -----------------------------------------------------------------------------
# These slots are documented now so the secret names are stable. Setting them
# without flipping BILLING_PROVIDER to a future implemented `stripe` provider
# has no effect.

# Stripe secret key. Test mode keys start with `sk_test_`, live keys with `sk_live_`.
STRIPE_SECRET_KEY=sk_test_xxx

# Stripe webhook signing secret used to verify incoming webhook payloads.
# Get this from `stripe listen` (CLI) or the Stripe Dashboard webhook page.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe publishable key, exposed to the browser via Vite. Test keys start
# with `pk_test_`, live keys with `pk_live_`. The `VITE_` prefix is required
# so Vite inlines it into the client bundle.
VITE_STRIPE_PUBLIC_KEY=pk_test_xxx
